    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "node e2e/settings-window.e2e.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "happy-dom": "^20.10.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
