{
  "name": "tokometer",
  "private": true,
  "version": "1.2.2",
  "description": "A tiny desktop widget that keeps your Claude Code usage in sight — with a pixel-art coworker.",
  "author": "Bradley Wadsworth <b.wadsworth@live.co.uk>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Waddas/Tokometer.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
